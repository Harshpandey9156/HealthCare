# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vitaltrack

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
